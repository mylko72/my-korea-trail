# =====================================================
# Notion API 설정
# https://www.notion.so/my-integrations 에서 발급
# =====================================================

# Notion 인테그레이션 API 토큰
NOTION_API_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion 데이터베이스 ID
# 데이터베이스 URL에서 추출: https://www.notion.so/{workspace}/{DATABASE_ID}?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =====================================================
# Google Maps API 설정
# https://console.cloud.google.com/ 에서 발급
# Maps JavaScript API 활성화 필요
# =====================================================

# 서버 사이드 전용 (노출 금지)
GOOGLE_MAPS_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# 클라이언트 사이드 노출용 (NEXT_PUBLIC_ 접두사 필수)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# =====================================================
# 사용 방법
# =====================================================
# 1. 이 파일을 복사하여 .env.local 파일을 생성하세요
#    cp .env.local.example .env.local
#
# 2. 각 값을 실제 API 키/토큰으로 채워주세요
#
# 3. .env.local은 .gitignore에 포함되어 있으므로 
#    절대 git에 커밋하지 마세요
